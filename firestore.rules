rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMemberOfParty(partyId) {
      return isAuthenticated() && 
             (
               isOrganizer() ||
               (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.partyId == partyId) ||
               (exists(/databases/$(database)/documents/parties/$(partyId)) &&
                request.auth.uid in get(/databases/$(database)/documents/parties/$(partyId)).data.members)
             );
    }

    function isOrganizerOfParty(partyId) {
      return isAuthenticated() && 
             (
               isOrganizer() ||
               (exists(/databases/$(database)/documents/parties/$(partyId)) &&
                (get(/databases/$(database)/documents/parties/$(partyId)).data.ownerUid == request.auth.uid ||
                 get(/databases/$(database)/documents/parties/$(partyId)).data.memberRoles[request.auth.uid] == 'organizer'))
             );
    }

    function isOrganizer() {
      return isAuthenticated() && 
             (
               (request.auth.token.email in ["bottaridennis@gmail.com", "dennisbottari@gmail.com"] && request.auth.token.email_verified == true) ||
               (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'organizer')
             );
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data, isCreate) {
      let baseValid = data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() < 100 &&
             (!('partyId' in data) || data.partyId is string) &&
             (!('partyIds' in data) || data.partyIds is list);
      
      // Prevent self-escalation to organizer
      let roleValid = !('role' in data) || 
                      (data.role == 'participant') || 
                      (isCreate == false && data.role == resource.data.role) ||
                      isOrganizer();
      
      return baseValid && roleValid;
    }

    function isValidParty(data) {
      return data.keys().hasAll(['name', 'inviteCode', 'ownerUid', 'members']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.inviteCode is string && data.inviteCode.size() == 6 &&
             data.ownerUid is string &&
             data.members is list && data.members.size() > 0 && data.members.size() < 50 &&
             (!('memberRoles' in data) || data.memberRoles is map) &&
             (!('memberStatus' in data) || data.memberStatus is map);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['partyId', 'name', 'quantity', 'type', 'broughtBy']) &&
             data.partyId is string &&
             data.name is string &&
             data.quantity is number &&
             data.type in ['food', 'drink'] &&
             data.broughtBy is string &&
             (!('brand' in data) || data.brand is string) &&
             (!('price' in data) || data.price is number) &&
             (!('alcoholContent' in data) || data.alcoholContent is number) &&
             (!('fillLevel' in data) || data.fillLevel is number) &&
             (!('expiryDate' in data) || data.expiryDate is string) &&
             (!('labels' in data) || data.labels is list) &&
             (!('allergens' in data) || data.allergens is string) &&
             (!('imageUrl' in data) || data.imageUrl is string) &&
             (!('lastUpdated' in data) || data.lastUpdated is string) &&
             (!('updatedBy' in data) || (data.updatedBy == null || data.updatedBy is string)) &&
             (!('category' in data) || data.category is string);
    }

    function isValidParticipant(data) {
      return data.keys().hasAll(['partyId', 'name', 'createdAt']) &&
             data.partyId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('group' in data) || (data.group is string && data.group.size() < 100)) &&
             (!('role' in data) || (data.role is string && data.role.size() < 100)) &&
             (!('email' in data) || (data.email is string && data.email.size() < 100)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 500));
    }

    function isValidDictionaryItem(data) {
      return data.keys().hasAll(['partyId', 'name']) &&
             data.partyId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['partyId', 'date', 'description', 'organizer']) &&
             data.partyId is string &&
             data.date is string &&
             data.description is string && data.description.size() > 0 && data.description.size() < 1000 &&
             data.organizer is string && data.organizer.size() > 0 && data.organizer.size() < 100 &&
             (!('participantId' in data) || data.participantId is string);
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(['partyId', 'timestamp', 'action', 'entityType', 'entityId', 'entityName', 'userId', 'userName', 'details']) &&
             data.partyId is string &&
             data.timestamp is string &&
             data.action in ['create', 'update', 'delete', 'move', 'auth'] &&
             data.entityType in ['product', 'participant', 'party', 'category', 'group', 'role', 'log'] &&
             data.entityId is string &&
             data.entityName is string &&
             data.userId is string &&
             data.userName is string &&
             data.details is string;
    }

    function isValidRequest(data) {
      return data.keys().hasAll(['partyId', 'userId', 'userName', 'productId', 'productName', 'quantity', 'type', 'status', 'createdAt']) &&
             data.partyId is string &&
             data.userId is string &&
             data.userName is string &&
             data.productId is string &&
             data.productName is string &&
             data.quantity is number && data.quantity > 0 &&
             data.type in ['withdraw', 'return'] &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isOrganizer();
      allow create: if isOwner(userId) && isValidUser(request.resource.data, true);
      allow update: if isOwner(userId) && isValidUser(request.resource.data, false);
    }

    match /parties/{partyId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
                    isValidParty(request.resource.data) && 
                    request.resource.data.ownerUid == request.auth.uid;
      
      allow update: if isAuthenticated() && 
                    isValidParty(request.resource.data) &&
                    request.resource.data.ownerUid == resource.data.ownerUid &&
                    (
                      (request.auth.uid == resource.data.ownerUid) || // Owner can update
                      (
                        request.resource.data.members.hasAll(resource.data.members) &&
                        request.resource.data.members.size() == resource.data.members.size() + 1 &&
                        request.auth.uid in request.resource.data.members &&
                        request.resource.data.inviteCode == resource.data.inviteCode &&
                        request.resource.data.memberRoles.keys().hasAll(resource.data.memberRoles.keys()) &&
                        request.resource.data.memberStatus.keys().hasAll(resource.data.memberStatus.keys())
                      ) // Joining
                    );
      
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.ownerUid;
    }

    match /products/{productId} {
      allow read: if isAuthenticated() && isMemberOfParty(resource.data.partyId);
      
      allow create: if isAuthenticated() && 
                      isMemberOfParty(request.resource.data.partyId) &&
                      isValidProduct(request.resource.data);
      
      allow update: if isAuthenticated() && 
                    isMemberOfParty(resource.data.partyId) &&
                    isValidProduct(request.resource.data) &&
                    request.resource.data.partyId == resource.data.partyId &&
                    (isOrganizer() || resource.data.broughtBy == request.auth.uid || resource.data.broughtBy == 'common');
      
      allow delete: if isAuthenticated() && 
                    isMemberOfParty(resource.data.partyId) &&
                    isOrganizer();
    }

    match /pantry_logs/{logId} {
      allow read: if isAuthenticated() && isMemberOfParty(resource.data.partyId);
      
      allow create: if isAuthenticated() && 
                      isMemberOfParty(request.resource.data.partyId) &&
                      isValidLog(request.resource.data);
      
      allow update, delete: if isAuthenticated() && 
                             isMemberOfParty(resource.data.partyId) &&
                             isOrganizer();
    }

    match /participants/{participantId} {
      allow read: if isAuthenticated() && (isOrganizer() || isMemberOfParty(resource.data.partyId));
      
      allow create: if isAuthenticated() && 
                      isMemberOfParty(request.resource.data.partyId) &&
                      isValidParticipant(request.resource.data);
      
      allow update: if isAuthenticated() && 
                    isMemberOfParty(resource.data.partyId) &&
                    isValidParticipant(request.resource.data) &&
                    request.resource.data.partyId == resource.data.partyId;
      
      allow delete: if isAuthenticated() && 
                    isMemberOfParty(resource.data.partyId) &&
                    isOrganizer();
    }

    match /categories/{id} {
      allow read: if isAuthenticated() && isMemberOfParty(resource.data.partyId);
      allow create, update: if isAuthenticated() && isMemberOfParty(request.resource.data.partyId) && isValidDictionaryItem(request.resource.data);
      allow delete: if isAuthenticated() && isMemberOfParty(resource.data.partyId) && isOrganizer();
    }

    match /groups/{id} {
      allow read: if isAuthenticated() && isMemberOfParty(resource.data.partyId);
      allow create, update: if isAuthenticated() && isMemberOfParty(request.resource.data.partyId) && isValidDictionaryItem(request.resource.data);
      allow delete: if isAuthenticated() && isMemberOfParty(resource.data.partyId) && isOrganizer();
    }

    match /participant_roles/{id} {
      allow read: if isAuthenticated() && isMemberOfParty(resource.data.partyId);
      allow create, update: if isAuthenticated() && isMemberOfParty(request.resource.data.partyId) && isValidDictionaryItem(request.resource.data);
      allow delete: if isAuthenticated() && isMemberOfParty(resource.data.partyId) && isOrganizer();
    }

    match /audit_logs/{logId} {
      allow read: if isAuthenticated() && isOrganizerOfParty(resource.data.partyId);
      allow create: if isAuthenticated() && isMemberOfParty(request.resource.data.partyId) && isValidAuditLog(request.resource.data);
      allow update, delete: if false;
    }

    match /product_requests/{requestId} {
      allow read: if isAuthenticated() && isMemberOfParty(resource.data.partyId);
      allow create: if isAuthenticated() && isMemberOfParty(request.resource.data.partyId) && isValidRequest(request.resource.data);
      allow update: if isAuthenticated() && isMemberOfParty(resource.data.partyId) && (isOrganizer() || (isOwner(resource.data.userId) && request.resource.data.status == resource.data.status));
      allow delete: if isAuthenticated() && isMemberOfParty(resource.data.partyId) && isOrganizer();
    }
  }
}
