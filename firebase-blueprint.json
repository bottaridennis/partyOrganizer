{
  "entities": {
    "Product": {
      "title": "Prodotto Dispensa",
      "description": "Cibo o bevanda per la festa",
      "type": "object",
      "properties": {
        "partyId": { "type": "string", "description": "ID della festa" },
        "name": { "type": "string", "description": "Nome del prodotto" },
        "brand": { "type": "string", "description": "Marca" },
        "code": { "type": "string", "description": "Codice identificativo" },
        "quantity": { "type": "number", "description": "Quantità disponibile" },
        "minQuantity": { "type": "number", "description": "Soglia minima" },
        "type": { "type": "string", "enum": ["food", "drink"] },
        "category": { "type": "string", "description": "Categoria (es. Snack, Alcolici)" },
        "price": { "type": "number", "description": "Prezzo" },
        "alcoholContent": { "type": "number", "description": "Gradazione alcolica (%)" },
        "fillLevel": { "type": "number", "description": "Percentuale di riempimento (0-100)" },
        "expiryDate": { "type": "string", "format": "date", "description": "Data di scadenza" },
        "labels": { "type": "array", "items": { "type": "string" }, "description": "Etichette (Alcolico, Analcolico, Senza Glutine)" },
        "allergens": { "type": "string", "description": "Allergeni vari" },
        "imageUrl": { "type": "string", "description": "Link immagine" },
        "broughtBy": { "type": "string", "description": "ID del partecipante o 'common'" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["partyId", "name", "quantity", "type", "broughtBy"]
    },
    "PantryLog": {
      "title": "Log Dispensa",
      "description": "Registrazione di un prelievo o aggiunta",
      "type": "object",
      "properties": {
        "partyId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "productsUsed": {
          "type": "array",
          "items": {
            "object": {
              "properties": {
                "productId": { "type": "string" },
                "productName": { "type": "string" },
                "quantity": { "type": "number" },
                "type": { "type": "string", "enum": ["withdraw", "return"] }
              }
            }
          }
        },
        "organizer": { "type": "string", "description": "Nome dell'organizzatore" },
        "participantId": { "type": "string", "description": "ID del partecipante" }
      },
      "required": ["partyId", "date", "description", "organizer"]
    },
    "User": {
      "title": "Utente",
      "description": "Profilo utente del sistema",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["organizer", "participant"] },
        "partyId": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Party": {
      "title": "Festa",
      "description": "Un evento condiviso tra amici",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "inviteCode": { "type": "string" },
        "ownerUid": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "inviteCode", "ownerUid", "members"]
    },
    "Participant": {
      "title": "Partecipante",
      "description": "Un amico che partecipa alla festa",
      "type": "object",
      "properties": {
        "partyId": { "type": "string" },
        "name": { "type": "string" },
        "group": { "type": "string", "description": "Gruppo di appartenenza" },
        "code": { "type": "string", "description": "Codice identificativo" },
        "email": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["partyId", "name", "createdAt"]
    },
    "Category": {
      "title": "Categoria",
      "description": "Categoria per i prodotti (es. Snack, Bevande)",
      "type": "object",
      "properties": {
        "partyId": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["partyId", "name"]
    },
    "Group": {
      "title": "Gruppo",
      "description": "Gruppo di amici",
      "type": "object",
      "properties": {
        "partyId": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["partyId", "name"]
    },
    "ParticipantRole": {
      "title": "Ruolo Partecipante",
      "description": "Ruolo all'interno della festa",
      "type": "object",
      "properties": {
        "partyId": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["partyId", "name"]
    },
    "ProductRequest": {
      "title": "Richiesta Prodotto",
      "description": "Richiesta di prelievo o aggiunta",
      "type": "object",
      "properties": {
        "partyId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "type": { "type": "string", "enum": ["withdraw", "return"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["partyId", "userId", "userName", "productId", "productName", "quantity", "type", "status", "createdAt"]
    },
    "AuditLog": {
      "title": "Registro Audit",
      "description": "Log di sistema per azioni critiche",
      "type": "object",
      "properties": {
        "partyId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "action": { "type": "string" },
        "entityType": { "type": "string" },
        "entityId": { "type": "string" },
        "entityName": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "details": { "type": "string" }
      },
      "required": ["partyId", "timestamp", "action", "entityType", "entityId", "entityName", "userId", "userName", "details"]
    }
  },
  "firestore": {
    "/products": { "schema": "Product", "description": "Inventario prodotti festa" },
    "/pantry_logs": { "schema": "PantryLog", "description": "Storico movimenti dispensa" },
    "/users": { "schema": "User", "description": "Dati utenti" },
    "/parties": { "schema": "Party", "description": "Dati feste" },
    "/participants": { "schema": "Participant", "description": "Dati partecipanti" },
    "/categories": { "schema": "Category", "description": "Dizionario categorie" },
    "/groups": { "schema": "Group", "description": "Dizionario gruppi" },
    "/participant_roles": { "schema": "ParticipantRole", "description": "Dizionario ruoli" },
    "/product_requests": { "schema": "ProductRequest", "description": "Richieste di prelievo" },
    "/audit_logs": { "schema": "AuditLog", "description": "Log di audit" }
  }
}
